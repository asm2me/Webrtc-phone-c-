<Project Sdk="Microsoft.NET.Sdk.WindowsDesktop">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net6.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <RootNamespace>WebRtcPhoneDialer</RootNamespace>
    <AssemblyName>WebRtcPhoneDialer</AssemblyName>
    <StartupObject>WebRtcPhoneDialer.App</StartupObject>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <!-- corrected package ID; original 'google-api-dotnet-client' does not exist on nuget.org -->
    <PackageReference Include="Google.Apis" Version="1.68.0" />
    <PackageReference Include="RestSharp" Version="107.3.0" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    <PackageReference Include="NLog" Version="5.2.7" />
  </ItemGroup>

  <ItemGroup>
    <Folder Include="Properties\" />
  </ItemGroup>

</Project>
