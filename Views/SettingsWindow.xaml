<Window x:Class="WebRtcPhoneDialer.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="580" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0D0D1A">

    <Window.Resources>
        <!-- Dark text input -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#12122A"/>
            <Setter Property="Foreground" Value="#E0E0F0"/>
            <Setter Property="CaretBrush" Value="#7C4DFF"/>
            <Setter Property="BorderBrush" Value="#2A2A45"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <Grid>
                                <TextBlock x:Name="Placeholder"
                                           Text="{TemplateBinding Tag}"
                                           Foreground="#3A3A55" FontStyle="Italic"
                                           Margin="8,0,0,0" VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                                <ScrollViewer x:Name="PART_ContentHost" Margin="2,0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#536DFE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark password box -->
        <Style x:Key="DarkPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background" Value="#12122A"/>
            <Setter Property="Foreground" Value="#E0E0F0"/>
            <Setter Property="CaretBrush" Value="#7C4DFF"/>
            <Setter Property="BorderBrush" Value="#2A2A45"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>

        <!-- Dark combo box -->
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#12122A"/>
            <Setter Property="Foreground" Value="#E0E0F0"/>
            <Setter Property="BorderBrush" Value="#2A2A45"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>

        <!-- Dark label -->
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#AAAACC"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- Dark checkbox -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CCCCEE"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- Tab item dark style -->
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#8888AA"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border" CornerRadius="6,6,0,0" Padding="14,6" Margin="2,0"
                                Background="Transparent" BorderThickness="0">
                            <ContentPresenter x:Name="ContentSite"
                                              ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1A1A2E"/>
                                <Setter Property="Foreground" Value="#CCCCEE"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#15152A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark GroupBox -->
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="#AAAACC"/>
            <Setter Property="BorderBrush" Value="#2A2A45"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Padding" Value="10"/>
        </Style>

        <!-- Settings action button -->
        <Style x:Key="SettingsBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" CornerRadius="6" Padding="16,6"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Margin="10,10,10,0"
                    Background="#0D0D1A" BorderBrush="#2A2A45">

            <!-- ===== Tab 1: Service ===== -->
            <TabItem Header="Service">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#0D0D1A">
                    <StackPanel Margin="10">

                        <GroupBox Header="WebRTC &amp; Signaling">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Label Grid.Row="0" Grid.Column="0" Content="Username:" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="0" Grid.Column="1"
                                         Style="{StaticResource DarkTextBox}"
                                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                         Tag="e.g. 1000"/>

                                <Label Grid.Row="1" Grid.Column="0" Content="Password:" VerticalAlignment="Center"/>
                                <PasswordBox Grid.Row="1" Grid.Column="1"
                                             Style="{StaticResource DarkPasswordBox}"
                                             x:Name="WebRtcPasswordBox"/>

                                <Label Grid.Row="2" Grid.Column="0" Content="STUN Server:" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="2" Grid.Column="1"
                                         Style="{StaticResource DarkTextBox}"
                                         Text="{Binding StunServer, UpdateSourceTrigger=PropertyChanged}"
                                         Tag="stun:stun.freeswitch.org"/>

                                <Label Grid.Row="3" Grid.Column="0" Content="TURN Server:" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="3" Grid.Column="1"
                                         Style="{StaticResource DarkTextBox}"
                                         Text="{Binding TurnServer, UpdateSourceTrigger=PropertyChanged}"
                                         Tag="turn:192.168.1.100:3478"/>

                                <Label Grid.Row="4" Grid.Column="0" Content="TURN User:" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="4" Grid.Column="1"
                                         Style="{StaticResource DarkTextBox}"
                                         Text="{Binding TurnUsername, UpdateSourceTrigger=PropertyChanged}"
                                         Tag="e.g. turnuser"/>

                                <Label Grid.Row="5" Grid.Column="0" Content="TURN Password:" VerticalAlignment="Center"/>
                                <PasswordBox Grid.Row="5" Grid.Column="1"
                                             Style="{StaticResource DarkPasswordBox}"
                                             x:Name="TurnPasswordBox"/>

                                <Label Grid.Row="6" Grid.Column="0" Content="ICE Servers:" VerticalAlignment="Top" Margin="0,8,0,0"/>
                                <TextBox Grid.Row="6" Grid.Column="1" Height="56" Margin="0,4" Padding="6,4"
                                         Background="#12122A" Foreground="#E0E0F0"
                                         BorderBrush="#2A2A45" CaretBrush="#7C4DFF"
                                         Text="{Binding IceServers, UpdateSourceTrigger=PropertyChanged}"
                                         TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

                                <Label Grid.Row="7" Grid.Column="0" Content="Signaling URL:" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="7" Grid.Column="1"
                                         Style="{StaticResource DarkTextBox}"
                                         Text="{Binding SignalingServerUrl, UpdateSourceTrigger=PropertyChanged}"
                                         Tag="wss://192.168.1.100:7443"/>

                                <Label Grid.Row="8" Grid.Column="0" Content="SIP Domain:" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="8" Grid.Column="1"
                                         Style="{StaticResource DarkTextBox}"
                                         Text="{Binding SipDomain, UpdateSourceTrigger=PropertyChanged}"
                                         Tag="e.g. 192.168.1.100"/>

                                <Label Grid.Row="9" Grid.Column="0" Content="Auth Token:" VerticalAlignment="Center"/>
                                <PasswordBox Grid.Row="9" Grid.Column="1"
                                             Style="{StaticResource DarkPasswordBox}"
                                             x:Name="AuthTokenBox"/>
                            </Grid>
                        </GroupBox>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ===== Tab 2: Audio ===== -->
            <TabItem Header="Audio">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#0D0D1A">
                <StackPanel Margin="10">

                    <GroupBox Header="Audio Devices">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <CheckBox Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                                      Content="Enable Audio" Margin="0,0,0,10"
                                      IsChecked="{Binding EnableAudio}"/>

                            <Label Grid.Row="1" Grid.Column="0" Content="Microphone:" VerticalAlignment="Center"/>
                            <ComboBox Grid.Row="1" Grid.Column="1"
                                      x:Name="InputDeviceCombo"
                                      IsEnabled="{Binding EnableAudio}"/>

                            <Label Grid.Row="2" Grid.Column="0" Content="Speaker:" VerticalAlignment="Center"/>
                            <ComboBox Grid.Row="2" Grid.Column="1"
                                      x:Name="OutputDeviceCombo"
                                      IsEnabled="{Binding EnableAudio}"/>
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="Volume">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="35"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Content="Input Volume:" VerticalAlignment="Center"/>
                            <Slider Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="100" TickFrequency="10"
                                    Value="{Binding InputVolume}" VerticalAlignment="Center" Margin="0,6"
                                    IsEnabled="{Binding EnableAudio}"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Margin="4,0,0,0"
                                       Foreground="#CCCCEE" Text="{Binding InputVolume}"/>

                            <Label Grid.Row="1" Grid.Column="0" Content="Output Volume:" VerticalAlignment="Center"/>
                            <Slider Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="100" TickFrequency="10"
                                    Value="{Binding OutputVolume}" VerticalAlignment="Center" Margin="0,6"
                                    IsEnabled="{Binding EnableAudio}"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Margin="4,0,0,0"
                                       Foreground="#CCCCEE" Text="{Binding OutputVolume}"/>
                            <Button Grid.Row="1" Grid.Column="3" Content="Test" Height="24" Margin="4,0,0,0"
                                    Background="#2A2A45" Foreground="#CCCCEE"
                                    IsEnabled="{Binding EnableAudio}"
                                    Click="TestOutputVolume_Click"/>
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="Processing">
                        <StackPanel>
                            <CheckBox Content="Echo Cancellation" Margin="0,0,0,8"
                                      IsChecked="{Binding EchoCancellation}"
                                      IsEnabled="{Binding EnableAudio}"/>
                            <CheckBox Content="Noise Suppression"
                                      IsChecked="{Binding NoiseSuppression}"
                                      IsEnabled="{Binding EnableAudio}"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Ringtone">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="35"/>
                                <ColumnDefinition Width="55"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Content="Ring Device:" VerticalAlignment="Center"/>
                            <ComboBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3"
                                      Margin="0,4"
                                      x:Name="RingDeviceCombo"/>

                            <Label Grid.Row="1" Grid.Column="0" Content="Ringtone:" VerticalAlignment="Center"/>
                            <ComboBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                                      Margin="0,4"
                                      x:Name="RingtoneCombo"
                                      ItemsSource="{Binding RingtoneOptions}"
                                      SelectedItem="{Binding RingtoneName}"/>
                            <Button Grid.Row="1" Grid.Column="3" Content="Play" Height="28" Margin="4,4,0,4"
                                    Background="#2A2A45" Foreground="#CCCCEE"
                                    Click="PreviewRingtone_Click"/>

                            <Label Grid.Row="2" Grid.Column="0" Content="Ring Volume:" VerticalAlignment="Center"/>
                            <Slider Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="100" TickFrequency="10"
                                    Value="{Binding RingVolume}" VerticalAlignment="Center" Margin="0,6"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" VerticalAlignment="Center" Margin="4,0,0,0"
                                       Foreground="#CCCCEE" Text="{Binding RingVolume}"/>
                        </Grid>
                    </GroupBox>

                </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ===== Tab 3: Codecs ===== -->
            <TabItem Header="Codecs">
                <StackPanel Margin="10" Background="#0D0D1A">

                    <GroupBox Header="Audio Codec">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Label Grid.Column="0" Content="Preferred Codec:" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AudioCodecOptions}"
                                      SelectedItem="{Binding AudioCodecName}"/>
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="Video">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <CheckBox Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                                      Content="Enable Video" Margin="0,0,0,10"
                                      IsChecked="{Binding EnableVideo}"/>

                            <Label Grid.Row="1" Grid.Column="0" Content="Preferred Codec:" VerticalAlignment="Center"/>
                            <ComboBox Grid.Row="1" Grid.Column="1"
                                      ItemsSource="{Binding VideoCodecOptions}"
                                      SelectedItem="{Binding VideoCodecName}"
                                      IsEnabled="{Binding EnableVideo}"/>
                        </Grid>
                    </GroupBox>

                </StackPanel>
            </TabItem>

        </TabControl>

        <!-- Bottom buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10,8,10,10">
            <Button Content="Cancel" Width="90" Height="32"
                    Style="{StaticResource SettingsBtn}"
                    Background="#2A2A45"
                    Margin="0,0,8,0"
                    Click="Cancel_Click"/>
            <Button Content="Save" Width="90" Height="32"
                    Style="{StaticResource SettingsBtn}"
                    Click="Save_Click">
                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#536DFE" Offset="0"/>
                        <GradientStop Color="#7C4DFF" Offset="1"/>
                    </LinearGradientBrush>
                </Button.Background>
            </Button>
        </StackPanel>

    </Grid>
</Window>
