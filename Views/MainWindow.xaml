<Window x:Class="WebRtcPhoneDialer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WebRTC Phone Dialer" Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <DockPanel Grid.Row="0" Background="#EEEEEE" LastChildFill="False" Height="40">
            <TextBlock DockPanel.Dock="Left"
                       Text="WebRTC Phone Dialer"
                       FontSize="16" FontWeight="Bold"
                       Foreground="#333333"
                       VerticalAlignment="Center"
                       Margin="16,0,0,0"/>

            <!-- Right-side items (added right-to-left in DockPanel) -->
            <Button DockPanel.Dock="Right"
                    Content="⚙ Settings"
                    Width="90" Height="28"
                    Margin="0,0,10,0"
                    Background="#607D8B" Foreground="White"
                    Click="Settings_Click"/>
            <Button DockPanel.Dock="Right"
                    Content="Debug"
                    Width="70" Height="28"
                    Margin="0,0,6,0"
                    Background="#607D8B" Foreground="White"
                    Click="Debug_Click"/>
            <Button DockPanel.Dock="Right"
                    x:Name="RegisterButton"
                    Content="Register"
                    Width="80" Height="28"
                    Margin="0,0,6,0"
                    Background="#2196F3" Foreground="White" FontWeight="Bold"
                    Click="Register_Click"/>

            <!-- Registration status indicator -->
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="0,0,10,0">
                <Ellipse x:Name="StatusDot" Width="12" Height="12" Fill="#9E9E9E"/>
                <TextBlock x:Name="StatusText"
                           Text="Unregistered"
                           FontSize="12" Foreground="#555555"
                           VerticalAlignment="Center" Margin="5,0,0,0"/>
            </StackPanel>
        </DockPanel>

        <!-- Main content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Orientation="Vertical" Margin="20">

                <!-- Call Status -->
                <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Call Status" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock x:Name="CallStatusText"
                                   Text="Ready"
                                   FontSize="14"
                                   Foreground="#666666"/>
                        <TextBlock x:Name="CallDurationText"
                                   Text="Duration: 00:00:00"
                                   FontSize="12"
                                   Foreground="#999999"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Phone Number Input -->
                <StackPanel Margin="0,0,0,15">
                    <Label Content="Phone Number or SIP URI:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="PhoneNumberInput"
                             Height="40"
                             Padding="10"
                             FontSize="16"
                             Foreground="#333333"/>
                </StackPanel>

                <!-- Dialer Pad -->
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="50"/>
                    </Grid.RowDefinitions>

                    <Button Content="1" Click="DialerButton_Click" Margin="5" Background="#E8E8E8" Grid.Column="0" Grid.Row="0"/>
                    <Button Content="2" Click="DialerButton_Click" Margin="5" Background="#E8E8E8" Grid.Column="1" Grid.Row="0"/>
                    <Button Content="3" Click="DialerButton_Click" Margin="5" Background="#E8E8E8" Grid.Column="2" Grid.Row="0"/>

                    <Button Content="4" Click="DialerButton_Click" Margin="5" Background="#E8E8E8" Grid.Column="0" Grid.Row="1"/>
                    <Button Content="5" Click="DialerButton_Click" Margin="5" Background="#E8E8E8" Grid.Column="1" Grid.Row="1"/>
                    <Button Content="6" Click="DialerButton_Click" Margin="5" Background="#E8E8E8" Grid.Column="2" Grid.Row="1"/>

                    <Button Content="7" Click="DialerButton_Click" Margin="5" Background="#E8E8E8" Grid.Column="0" Grid.Row="2"/>
                    <Button Content="8" Click="DialerButton_Click" Margin="5" Background="#E8E8E8" Grid.Column="1" Grid.Row="2"/>
                    <Button Content="9" Click="DialerButton_Click" Margin="5" Background="#E8E8E8" Grid.Column="2" Grid.Row="2"/>

                    <Button Content="*" Click="DialerButton_Click" Margin="5" Background="#E8E8E8" Grid.Column="0" Grid.Row="3"/>
                    <Button Content="0" Click="DialerButton_Click" Margin="5" Background="#E8E8E8" Grid.Column="1" Grid.Row="3"/>
                    <Button Content="#" Click="DialerButton_Click" Margin="5" Background="#E8E8E8" Grid.Column="2" Grid.Row="3"/>
                </Grid>

                <!-- Control Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="CallButton"
                            Content="Call"
                            Width="120"
                            Height="50"
                            Background="#4CAF50"
                            Foreground="White"
                            FontSize="16"
                            FontWeight="Bold"
                            Click="CallButton_Click"/>
                    <Button x:Name="HangupButton"
                            Content="Hang Up"
                            Width="120"
                            Height="50"
                            Background="#F44336"
                            Foreground="White"
                            FontSize="16"
                            FontWeight="Bold"
                            Click="HangupButton_Click"
                            IsEnabled="False"/>
                    <Button Content="Clear"
                            Width="120"
                            Height="50"
                            Background="#2196F3"
                            Foreground="White"
                            FontSize="16"
                            FontWeight="Bold"
                            Click="Clear_Click"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
