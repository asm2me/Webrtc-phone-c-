<Window x:Class="WebRtcPhoneDialer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VOIPAT Phone" Height="820" Width="420"
        Icon="pack://application:,,,/WebRtcPhoneDialer;component/voipat.ico"
        WindowStartupLocation="CenterScreen"
        Background="#0D0D1A"
        ResizeMode="CanMinimize"
        Closing="Window_Closing"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <!-- Dialer pad button style -->
        <Style x:Key="DialerBtn" TargetType="Button">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Light"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Width" Value="72"/>
            <Setter Property="Height" Value="72"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="bg" Fill="#1A1A2E"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Fill" Value="#2A2A45"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Fill" Value="#3A3A5C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Action button base (call, hangup) -->
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Width" Value="72"/>
            <Setter Property="Height" Value="72"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Call button (green circle) -->
        <Style x:Key="CallBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="bg">
                                <Ellipse.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#00C853" Offset="0"/>
                                        <GradientStop Color="#009624" Offset="1"/>
                                    </LinearGradientBrush>
                                </Ellipse.Fill>
                            </Ellipse>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Fill">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#2EFF6E" Offset="0"/>
                                            <GradientStop Color="#00C853" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bg" Property="Fill" Value="#1A1A2E"/>
                                <Setter Property="Foreground" Value="#555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Hangup button (red circle) -->
        <Style x:Key="HangupBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="bg">
                                <Ellipse.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#FF1744" Offset="0"/>
                                        <GradientStop Color="#D50000" Offset="1"/>
                                    </LinearGradientBrush>
                                </Ellipse.Fill>
                            </Ellipse>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Fill">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#FF5252" Offset="0"/>
                                            <GradientStop Color="#FF1744" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bg" Property="Fill" Value="#1A1A2E"/>
                                <Setter Property="Foreground" Value="#555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toolbar icon button -->
        <Style x:Key="ToolbarBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8888AA"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="Transparent" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#1A1A2E"/>
                                <Setter Property="Foreground" Value="#CCCCEE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Register button -->
        <Style x:Key="RegisterBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" CornerRadius="12" Padding="14,5">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#536DFE" Offset="0"/>
                                    <GradientStop Color="#7C4DFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#7C4DFF" Offset="0"/>
                                            <GradientStop Color="#B388FF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bg" Property="Background" Value="#2A2A45"/>
                                <Setter Property="Foreground" Value="#666"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ Top Bar ═══ -->
        <Border Grid.Row="0" Background="#0D0D1A" Padding="12,8">
            <DockPanel>
                <!-- Registration status (left) -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#555566" Margin="0,0,6,0"/>
                    <TextBlock x:Name="StatusText"
                               Text="Unregistered"
                               FontSize="11" Foreground="#8888AA"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Right-side buttons -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="RegisterButton"
                            Content="Register"
                            Style="{StaticResource RegisterBtn}"
                            Click="Register_Click"/>
                    <Button Content="Debug"
                            Style="{StaticResource ToolbarBtn}"
                            Margin="8,0,0,0"
                            Click="Debug_Click"/>
                    <Button Content="Settings"
                            Style="{StaticResource ToolbarBtn}"
                            Margin="4,0,0,0"
                            Click="Settings_Click"/>
                </StackPanel>

                <!-- Spacer -->
                <Border/>
            </DockPanel>
        </Border>

        <!-- ═══ Main Content ═══ -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Call Status Area -->
            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,18,0,6">
                <TextBlock x:Name="CallStatusText"
                           Text="Ready"
                           FontSize="16" FontWeight="Light"
                           Foreground="#CCCCEE"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="CallDurationText"
                           Text="00:00:00"
                           FontSize="28" FontWeight="Thin"
                           Foreground="#6C6C8A"
                           HorizontalAlignment="Center"
                           Margin="0,2,0,0"/>
            </StackPanel>

            <!-- Phone Number Input -->
            <Border Grid.Row="1" Margin="40,8,40,10" CornerRadius="8" Background="#12122A">
                <Grid>
                    <TextBox x:Name="PhoneNumberInput"
                             FontSize="22" FontWeight="Light"
                             Foreground="#E0E0F0"
                             CaretBrush="#7C4DFF"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="14,10"
                             VerticalContentAlignment="Center"
                             TextAlignment="Center"/>
                    <!-- Placeholder text -->
                    <TextBlock x:Name="InputPlaceholder"
                               Text="Enter number or SIP URI"
                               FontSize="14" FontWeight="Light"
                               Foreground="#3A3A55"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False"/>
                </Grid>
            </Border>

            <!-- Dialer Pad -->
            <Grid Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Button Content="1" Style="{StaticResource DialerBtn}" Click="DialerButton_Click" Grid.Column="0" Grid.Row="0"/>
                <Button Content="2" Style="{StaticResource DialerBtn}" Click="DialerButton_Click" Grid.Column="1" Grid.Row="0"/>
                <Button Content="3" Style="{StaticResource DialerBtn}" Click="DialerButton_Click" Grid.Column="2" Grid.Row="0"/>

                <Button Content="4" Style="{StaticResource DialerBtn}" Click="DialerButton_Click" Grid.Column="0" Grid.Row="1"/>
                <Button Content="5" Style="{StaticResource DialerBtn}" Click="DialerButton_Click" Grid.Column="1" Grid.Row="1"/>
                <Button Content="6" Style="{StaticResource DialerBtn}" Click="DialerButton_Click" Grid.Column="2" Grid.Row="1"/>

                <Button Content="7" Style="{StaticResource DialerBtn}" Click="DialerButton_Click" Grid.Column="0" Grid.Row="2"/>
                <Button Content="8" Style="{StaticResource DialerBtn}" Click="DialerButton_Click" Grid.Column="1" Grid.Row="2"/>
                <Button Content="9" Style="{StaticResource DialerBtn}" Click="DialerButton_Click" Grid.Column="2" Grid.Row="2"/>

                <Button Content="*" Style="{StaticResource DialerBtn}" Click="DialerButton_Click" Grid.Column="0" Grid.Row="3"/>
                <Button Content="0" Style="{StaticResource DialerBtn}" Click="DialerButton_Click" Grid.Column="1" Grid.Row="3"/>
                <Button Content="#" Style="{StaticResource DialerBtn}" Click="DialerButton_Click" Grid.Column="2" Grid.Row="3"/>
            </Grid>

            <!-- Action Buttons Row -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12">
                <Button x:Name="CallButton"
                        Style="{StaticResource CallBtn}"
                        Click="CallButton_Click"
                        ToolTip="Call">
                    <StackPanel>
                        <TextBlock Text="&#x260E;" FontSize="26" HorizontalAlignment="Center" FontFamily="Segoe UI Symbol"/>
                    </StackPanel>
                </Button>

                <Button x:Name="HoldButton"
                        Style="{StaticResource DialerBtn}"
                        Click="HoldButton_Click"
                        IsEnabled="False"
                        Width="56" Height="56"
                        ToolTip="Hold / Resume">
                    <TextBlock x:Name="HoldButtonText" Text="&#x23F8;" FontSize="18" FontFamily="Segoe UI Symbol"/>
                </Button>

                <Button x:Name="HangupButton"
                        Style="{StaticResource HangupBtn}"
                        Click="HangupButton_Click"
                        IsEnabled="False"
                        ToolTip="Hang Up">
                    <StackPanel>
                        <TextBlock Text="&#x2716;" FontSize="22" HorizontalAlignment="Center" FontFamily="Segoe UI Symbol"/>
                    </StackPanel>
                </Button>

                <!-- Clear / backspace button -->
                <Button Style="{StaticResource DialerBtn}"
                        Click="Clear_Click"
                        Width="56" Height="56"
                        ToolTip="Clear">
                    <TextBlock Text="&#x232B;" FontSize="20" FontFamily="Segoe UI Symbol"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ═══ Call History Log (docked bottom) ═══ -->
        <Border Grid.Row="2" Background="#0F0F22" Margin="0,0,0,0" BorderBrush="#1A1A2E" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header bar -->
                <Border Grid.Row="0" Background="#0A0A1A" Padding="14,7,14,7">
                    <DockPanel>
                        <TextBlock Text="Call History"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="#8888AA"
                                   VerticalAlignment="Center"/>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock x:Name="HistoryCountText"
                                       Text="{Binding CallHistory.Count, StringFormat='{}{0} calls'}"
                                       FontSize="11" Foreground="#555570"
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Button Content="Clear All"
                                    Style="{StaticResource ToolbarBtn}"
                                    FontSize="11"
                                    Click="ClearHistory_Click"/>
                        </StackPanel>
                        <Border/>
                    </DockPanel>
                </Border>

                <!-- History List -->
                <ListBox x:Name="CallHistoryList"
                         Grid.Row="1"
                         ItemsSource="{Binding CallHistory}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         MouseDoubleClick="CallHistoryList_MouseDoubleClick"
                         Padding="0">
                    <!-- Right-click context menu -->
                    <ListBox.ContextMenu>
                        <ContextMenu Background="#1A1A2E" BorderBrush="#2A2A45" Foreground="#CCCCEE">
                            <MenuItem Header="Dial" Click="HistoryDial_Click" FontSize="12"/>
                            <MenuItem Header="Copy Number" Click="HistoryCopyNumber_Click" FontSize="12"/>
                            <Separator Background="#2A2A45"/>
                            <MenuItem Header="Remove" Click="HistoryRemove_Click" FontSize="12"/>
                        </ContextMenu>
                    </ListBox.ContextMenu>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#CCCCEE"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd" Background="Transparent" Padding="14,8" BorderBrush="#14142A" BorderThickness="0,0,0,1">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#151530"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#1A1A3A"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- State indicator dot -->
                                <Ellipse Grid.Column="0" Grid.RowSpan="2"
                                         Width="10" Height="10"
                                         VerticalAlignment="Center"
                                         Margin="0,0,10,0">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#6C6C8A"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding State}" Value="Connected">
                                                    <Setter Property="Fill" Value="#00E676"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding State}" Value="Ended">
                                                    <Setter Property="Fill" Value="#00E676"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding State}" Value="Failed">
                                                    <Setter Property="Fill" Value="#FF1744"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>

                                <!-- Remote party number -->
                                <TextBlock Grid.Column="1" Grid.Row="0"
                                           Text="{Binding RemoteParty}"
                                           FontSize="14" FontWeight="Medium"
                                           Foreground="#E0E0F0"
                                           TextTrimming="CharacterEllipsis"/>

                                <!-- Date / time -->
                                <TextBlock Grid.Column="2" Grid.Row="0"
                                           Text="{Binding DateDisplay}"
                                           FontSize="11" Foreground="#6C6C8A"
                                           VerticalAlignment="Center"/>

                                <!-- Status + duration detail line -->
                                <StackPanel Grid.Column="1" Grid.Row="1" Grid.ColumnSpan="2"
                                            Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock FontSize="11" Margin="0,0,8,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{Binding StateDisplay}"/>
                                                <Setter Property="Foreground" Value="#6C6C8A"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding State}" Value="Failed">
                                                        <Setter Property="Foreground" Value="#FF5252"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="·" Foreground="#444460" FontSize="11" Margin="0,0,8,0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding DurationDisplay}"
                                               FontSize="11" Foreground="#555570"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Empty state -->
                <TextBlock Grid.Row="1"
                           Text="No calls yet"
                           FontSize="13" Foreground="#3A3A55"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CallHistory.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>
