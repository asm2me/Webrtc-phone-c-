<Window x:Class="WebRtcPhoneDialer.Views.DebugWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Debug Info" Height="450" Width="520"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Debug Information"
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

        <Border Grid.Row="1" Background="White"
                BorderBrush="#CCCCCC" BorderThickness="1"
                CornerRadius="4" Padding="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="DebugText"
                           FontFamily="Consolas" FontSize="12"
                           TextWrapping="Wrap"
                           Foreground="#333333"/>
            </ScrollViewer>
        </Border>

        <Button Grid.Row="2" Content="Refresh"
                Width="90" Height="30"
                HorizontalAlignment="Right" Margin="0,10,0,0"
                Background="#607D8B" Foreground="White"
                Click="Refresh_Click"/>
    </Grid>
</Window>
