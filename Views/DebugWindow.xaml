<Window x:Class="WebRtcPhoneDialer.Views.DebugWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Debug / SIP Log" Height="620" Width="740"
        WindowStartupLocation="CenterOwner"
        Background="#F0F0F0">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Status summary -->
        <GroupBox Grid.Row="0" Header="Status" Margin="0,0,0,6" Padding="8,6">
            <TextBlock x:Name="StatusText"
                       FontFamily="Consolas" FontSize="11"
                       TextWrapping="Wrap" LineHeight="18"/>
        </GroupBox>

        <!-- Audio level meters -->
        <GroupBox Grid.Row="1" Header="Audio Levels" Margin="0,0,0,6" Padding="8,4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="62"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="42"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Mic:"
                           FontFamily="Consolas" FontSize="11" VerticalAlignment="Center"/>
                <ProgressBar Grid.Row="0" Grid.Column="1" x:Name="MicLevelBar"
                             Height="14" Margin="4,2" Minimum="0" Maximum="100" Value="0"
                             Foreground="#4EC9B0" Background="#1E1E1E"/>
                <TextBlock Grid.Row="0" Grid.Column="2" x:Name="MicLevelText"
                           FontFamily="Consolas" FontSize="10" VerticalAlignment="Center"
                           HorizontalAlignment="Right" Text="0%"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Speaker:"
                           FontFamily="Consolas" FontSize="11" VerticalAlignment="Center"/>
                <ProgressBar Grid.Row="1" Grid.Column="1" x:Name="SpeakerLevelBar"
                             Height="14" Margin="4,2" Minimum="0" Maximum="100" Value="0"
                             Foreground="#569CD6" Background="#1E1E1E"/>
                <TextBlock Grid.Row="1" Grid.Column="2" x:Name="SpeakerLevelText"
                           FontFamily="Consolas" FontSize="10" VerticalAlignment="Center"
                           HorizontalAlignment="Right" Text="0%"/>
            </Grid>
        </GroupBox>

        <!-- SIP traffic log (dark terminal style) -->
        <GroupBox Grid.Row="2" Header="SIP Traffic Log" Padding="0">
            <RichTextBox x:Name="SipLog"
                         Background="#1E1E1E"
                         BorderThickness="0"
                         IsReadOnly="True"
                         FontFamily="Consolas" FontSize="11"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         Padding="6"/>
        </GroupBox>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Clear Log" Width="90" Height="28" Margin="0,0,8,0"
                    Click="ClearLog_Click"/>
            <Button Content="Refresh" Width="90" Height="28"
                    Background="#607D8B" Foreground="White"
                    Click="Refresh_Click"/>
        </StackPanel>
    </Grid>
</Window>
